---
import '../styles/global.css';
import { navigation, siteConfig } from '../config/site';

interface Props {
	title?: string;
	description?: string;
}

const { title = siteConfig.title, description = siteConfig.description } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const faviconPath = `${baseUrl}favicon.svg`;
const faviconIcoPath = `${baseUrl}favicon.ico`;

const linkUrl = (path: string) => `${baseUrl}${path}`;
const normalizePath = (value: string) => (value.endsWith('/') ? value : `${value}/`);
const currentPath = normalizePath(Astro.url.pathname);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href={faviconPath} />
		<link rel="icon" href={faviconIcoPath} />
		<title>{title}</title>
	</head>
	<body>
		<div class="page-shell">
			<header class="site-header">
				<div class="container header-inner">
					<a class="site-brand" href={baseUrl}>
						<span class="brand-mark">love</span>
						<span class="brand-text">
							<strong>{siteConfig.title}</strong>
							<small>{siteConfig.subtitle}</small>
						</span>
					</a>
					<nav class="site-nav" aria-label="主导航">
						{
							navigation.map((item) => {
								const href = linkUrl(item.path);
								const isActive =
									item.path === ''
										? currentPath === normalizePath(href)
										: currentPath.startsWith(normalizePath(href));

								return (
									<a class:list={['nav-link', { active: isActive }]} href={href}>
										{item.label}
									</a>
								);
							})
						}
					</nav>
				</div>
			</header>
			<main class="page-main">
				<div class="container">
					<slot />
				</div>
			</main>
			<footer class="site-footer">
				<div class="container footer-inner">
					<div class="footer-copy">
						<p class="eyebrow">With Love</p>
						<h2 class="footer-title">{siteConfig.title}</h2>
					</div>
				</div>
			</footer>
		</div>
	</body>
</html>
