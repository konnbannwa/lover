---
import { albumItems } from '../data/album';
import { siteConfig } from '../config/site';
import BaseLayout from '../layouts/BaseLayout.astro';

const baseUrl = import.meta.env.BASE_URL;
const withBase = (path: string) => `${baseUrl}${path.replace(/^\/+/, '')}`;
const totalPhotos = albumItems.reduce((sum, item) => sum + item.photos.length, 0);
---

<BaseLayout title={`相册 | ${siteConfig.title}`} description="用相册保存两个人的照片和场景。">
	<section class="section page-banner">
		<div>
			<p class="eyebrow">Album</p>
			<h1 class="section-title">相册</h1>
			<p class="section-text">
				这里先用静态占位图搭起结构，后续只需要替换图片文件和说明文字，就能逐渐变成你们自己的相册。
			</p>
		</div>
		<div class="surface-card banner-card">
			<p class="eyebrow">Photos</p>
			<h2 class="panel-title">{albumItems.length} 组相册</h2>
			<p class="panel-text">当前示例里一共放了 {totalPhotos} 张占位图，后面可以按一次旅行或某一天继续往组里追加。</p>
		</div>
	</section>

	<section class="section">
		<div class="album-grid">
			{
				albumItems.map((item) => (
					<article class="album-card">
						<div class:list={['album-preview-grid', `count-${Math.min(item.photos.length, 4)}`]}>
							{item.photos.slice(0, 4).map((photo) => (
								<img
									class="album-image"
									src={withBase(photo.image)}
									alt={photo.alt}
									loading="lazy"
								/>
							))}
						</div>
						<div class="album-content">
							<div class="album-topline">
								<p class="eyebrow">{item.date}</p>
								<span class="photo-count">{item.photos.length} 张照片</span>
							</div>
							<h3>{item.title}</h3>
							<p class="section-text">{item.description}</p>
							<p class="caption-line">{item.note}</p>
						</div>
					</article>
				))
			}
		</div>
	</section>
</BaseLayout>
