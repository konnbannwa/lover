---
import { getCollection } from 'astro:content';
import DiaryCard from '../../components/DiaryCard.astro';
import { siteConfig } from '../../config/site';
import BaseLayout from '../../layouts/BaseLayout.astro';

const baseUrl = import.meta.env.BASE_URL;
const diaryEntries = (await getCollection('diary')).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<BaseLayout title={`时间线 | ${siteConfig.title}`} description="按时间查看恋爱日记与纪念片段。">
	<section class="section page-banner">
		<div>
			<p class="eyebrow">Timeline</p>
			<h1 class="section-title">时间线</h1>
			<p class="section-text">
				这里按时间收纳每一篇日记。以后只要继续新增记录，它们就会自然出现在这条时间线里。
			</p>
		</div>
		<div class="surface-card banner-card">
			<p class="eyebrow">Entries</p>
			<h2 class="panel-title">{diaryEntries.length} 篇记录</h2>
			<p class="panel-text">每一次新增都会自然接进这条时间线里，适合长期慢慢写。</p>
		</div>
	</section>

	<section class="section">
		<header class="section-header">
			<p class="eyebrow">Entries</p>
			<h2 class="section-title">按时间慢慢翻看</h2>
		</header>
		<div class="timeline-list">
			{
				diaryEntries.map((entry) => (
					<DiaryCard
						title={entry.data.title}
						author={entry.data.author}
						date={entry.data.date}
						summary={entry.data.summary}
						href={`${baseUrl}timeline/${entry.id}/`}
					/>
				))
			}
		</div>
	</section>
</BaseLayout>
