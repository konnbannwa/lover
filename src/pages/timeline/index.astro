const latestMomentIndex = timelineMoments.length - 1;
const isValidDateString = (date: string) => !Number.isNaN(new Date(date).getTime());
const getMomentDateLabel = (date: string) => (isValidDateString(date) ? formatDisplayDate(date) : date);
---

<BaseLayout title={`时间线 | ${siteConfig.title}`} description="按时间查看恋爱日记与纪念片段。">
	<section class="section page-banner">
		<div>
			<p class="eyebrow">Timeline</p>
			<h1 class="section-title">时间线</h1>
			<p class="section-text">
				这里是我们的恋爱时间线！
			</p>
		</div>
		<div class="surface-card banner-card">
			<p class="eyebrow">Entries</p>
			<h2 class="panel-title">{diaryEntries.length} 篇记录</h2>
			<p class="panel-text">一些心里话！</p>
		</div>
	</section>

	<section class="section">
		<header class="section-header">
			<p class="eyebrow">Moments</p>
			<h2 class="section-title">date速递</h2>
		</header>
		<div class="memory-timeline surface-card" aria-label="回忆时间线">
			<div class="memory-timeline-scroll">
				<ol class="memory-timeline-track">
					{
						timelineMoments.map((moment, index) => (
							<li class:list={['memory-point', { 'is-latest': index === latestMomentIndex }]}>
								{
									isValidDateString(moment.date) ? (
										<time datetime={moment.date}>{getMomentDateLabel(moment.date)}</time>
									) : (
										<span class="memory-date">{getMomentDateLabel(moment.date)}</span>
									)
								}
								<span class="memory-dot" aria-hidden="true"></span>
								<strong>{moment.title}</strong>
								<p>{moment.description}</p>
							</li>
						))
					}
				</ol>
			</div>
		</div>
	</section>

	<section class="section">
		<header class="section-header">
			<p class="eyebrow">Entries</p>
			<h2 class="section-title">这里是日记簿！</h2>
		</header>
		<div class="timeline-list">
			{
				diaryEntries.map((entry) => (
					<DiaryCard
						title={entry.data.title}
						author={entry.data.author}
						date={entry.data.date}
						summary={entry.data.summary}
						href={`${baseUrl}timeline/${entry.id}/`}
					/>
				))
			}
		</div>
	</section>
</BaseLayout>
