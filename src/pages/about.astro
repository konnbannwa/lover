---
import { siteConfig } from '../config/site';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title={`关于 | ${siteConfig.title}`} description="关于这个恋爱日记小站的说明。">
	<section class="section">
		<article class="entry-shell about-single">
			<p class="eyebrow">About</p>
			<h1 class="section-title">关于这个小站</h1>
			<div class="about-body">
				<p>{siteConfig.aboutText}</p>
				{siteConfig.aboutParagraphs.map((paragraph) => <p>{paragraph}</p>)}
			</div>
		</article>
	</section>
</BaseLayout>
